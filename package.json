{
  "name": "gh-watcher",
  "version": "0.1.0",
  "description": "Terminal dashboard for GitHub pull requests and Dependabot security alerts.",
  "type": "module",
  "bin": {
    "gh-watcher": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "dev:watch": "tsx watch src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "ink": "^7.0.1",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "node-notifier": "^10.0.1",
    "open": "^10.1.2",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.7"
  }
}
